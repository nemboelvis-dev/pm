{
  "database": "SQLite",
  "schema_version": 2,
  "pragmas": {
    "foreign_keys": "ON",
    "journal_mode": "WAL",
    "busy_timeout_ms": 5000,
    "user_version": 2
  },
  "migrations": [
    {
      "from": 1,
      "to": 2,
      "change": "Dropped the UNIQUE constraint on boards.user_id so a user can own any number of boards. Recreates the boards table (RENAME, CREATE, INSERT...SELECT, DROP) under PRAGMA legacy_alter_table=ON so board_columns.board_id and chat_messages.board_id keep resolving to the table named \"boards\" instead of being silently rewritten to reference the renamed-away table."
    }
  ],
  "tables": [
    {
      "name": "users",
      "purpose": "Owns any number of boards; created via signup (POST /api/auth/register) or the seeded MVP demo account.",
      "columns": [
        {
          "name": "id",
          "type": "INTEGER",
          "constraints": ["PRIMARY KEY", "AUTOINCREMENT"]
        },
        {
          "name": "username",
          "type": "TEXT",
          "constraints": ["NOT NULL", "UNIQUE"]
        },
        {
          "name": "password_hash",
          "type": "TEXT",
          "constraints": ["NOT NULL"]
        },
        {
          "name": "created_at",
          "type": "TEXT",
          "constraints": ["NOT NULL"],
          "default": "CURRENT_TIMESTAMP"
        }
      ]
    },
    {
      "name": "boards",
      "purpose": "Stores a Kanban board owned by a user. A user may own any number of boards.",
      "columns": [
        {
          "name": "id",
          "type": "INTEGER",
          "constraints": ["PRIMARY KEY", "AUTOINCREMENT"]
        },
        {
          "name": "user_id",
          "type": "INTEGER",
          "constraints": ["NOT NULL"],
          "references": "users(id) ON DELETE CASCADE"
        },
        {
          "name": "title",
          "type": "TEXT",
          "constraints": ["NOT NULL"]
        },
        {
          "name": "created_at",
          "type": "TEXT",
          "constraints": ["NOT NULL"],
          "default": "CURRENT_TIMESTAMP"
        },
        {
          "name": "updated_at",
          "type": "TEXT",
          "constraints": ["NOT NULL"],
          "default": "CURRENT_TIMESTAMP"
        }
      ],
      "indexes": ["INDEX boards_user_id ON boards(user_id)"]
    },
    {
      "name": "board_columns",
      "purpose": "Stores the five fixed board columns; only title is user-editable.",
      "columns": [
        {
          "name": "id",
          "type": "INTEGER",
          "constraints": ["PRIMARY KEY", "AUTOINCREMENT"]
        },
        {
          "name": "board_id",
          "type": "INTEGER",
          "constraints": ["NOT NULL"],
          "references": "boards(id) ON DELETE CASCADE"
        },
        {
          "name": "title",
          "type": "TEXT",
          "constraints": ["NOT NULL"]
        },
        {
          "name": "position",
          "type": "INTEGER",
          "constraints": ["NOT NULL", "CHECK (position BETWEEN 0 AND 4)"]
        },
        {
          "name": "created_at",
          "type": "TEXT",
          "constraints": ["NOT NULL"],
          "default": "CURRENT_TIMESTAMP"
        },
        {
          "name": "updated_at",
          "type": "TEXT",
          "constraints": ["NOT NULL"],
          "default": "CURRENT_TIMESTAMP"
        }
      ],
      "table_constraints": ["UNIQUE (board_id, position)"],
      "application_rules": [
        "Initialization creates exactly five rows at positions 0 through 4.",
        "No API route creates, deletes, or reorders columns.",
        "Only title and updated_at may be changed after initialization."
      ]
    },
    {
      "name": "cards",
      "purpose": "Stores ordered Kanban cards within a column.",
      "columns": [
        {
          "name": "id",
          "type": "INTEGER",
          "constraints": ["PRIMARY KEY", "AUTOINCREMENT"]
        },
        {
          "name": "column_id",
          "type": "INTEGER",
          "constraints": ["NOT NULL"],
          "references": "board_columns(id) ON DELETE CASCADE"
        },
        {
          "name": "title",
          "type": "TEXT",
          "constraints": ["NOT NULL"]
        },
        {
          "name": "details",
          "type": "TEXT",
          "constraints": ["NOT NULL"],
          "default": "''"
        },
        {
          "name": "position",
          "type": "INTEGER",
          "constraints": ["NOT NULL", "CHECK (position >= 0)"]
        },
        {
          "name": "created_at",
          "type": "TEXT",
          "constraints": ["NOT NULL"],
          "default": "CURRENT_TIMESTAMP"
        },
        {
          "name": "updated_at",
          "type": "TEXT",
          "constraints": ["NOT NULL"],
          "default": "CURRENT_TIMESTAMP"
        }
      ],
      "table_constraints": ["UNIQUE (column_id, position)"],
      "indexes": ["INDEX cards_column_id ON cards(column_id)"]
    },
    {
      "name": "chat_messages",
      "purpose": "Stores the ordered AI conversation history for a board.",
      "columns": [
        {
          "name": "id",
          "type": "INTEGER",
          "constraints": ["PRIMARY KEY", "AUTOINCREMENT"]
        },
        {
          "name": "board_id",
          "type": "INTEGER",
          "constraints": ["NOT NULL"],
          "references": "boards(id) ON DELETE CASCADE"
        },
        {
          "name": "role",
          "type": "TEXT",
          "constraints": ["NOT NULL", "CHECK (role IN ('user', 'assistant'))"]
        },
        {
          "name": "content",
          "type": "TEXT",
          "constraints": ["NOT NULL"]
        },
        {
          "name": "created_at",
          "type": "TEXT",
          "constraints": ["NOT NULL"],
          "default": "CURRENT_TIMESTAMP"
        }
      ],
      "indexes": ["INDEX chat_messages_board_id_id ON chat_messages(board_id, id)"]
    }
  ],
  "relationships": [
    "users 1 -> many boards",
    "boards 1 -> 5 board_columns",
    "board_columns 1 -> many cards",
    "boards 1 -> many chat_messages"
  ],
  "initial_data": {
    "user": "Create the MVP user named 'user' with a salted password hash.",
    "board": "Create one board for the MVP user titled 'Kanban Studio'.",
    "columns": ["Backlog", "Discovery", "In Progress", "Review", "Done"],
    "cards": "Copy the eight existing demo cards from frontend/src/lib/kanban.ts in their current order.",
    "note": "POST /api/auth/register creates additional users the same way, each starting with one board titled 'My Board' and the same five empty columns."
  }
}
